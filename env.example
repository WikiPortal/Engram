# ─────────────────────────────────────────────────────────────────
# Engram — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────
# Choose one: gemini | openai | anthropic | deepseek
LLM_PROVIDER=gemini
# LLM_MODEL=                          # optional model override

# API keys — only the one for your chosen provider is required
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# DEEPSEEK_API_KEY=your_deepseek_key

# ── Auth ──────────────────────────────────────────────────────────
# Change this to any long random string — used to sign JWT tokens
AUTH_SECRET=change-this-to-a-long-random-secret

# ── PostgreSQL ────────────────────────────────────────────────────
# Option A — Local Docker (default)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=engram
POSTGRES_USER=engram
POSTGRES_PASSWORD=engram_secret

# Option B — Hosted (Neon, Supabase, Railway) — overrides Option A
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ── Qdrant ────────────────────────────────────────────────────────
# Option A — Local Docker (default)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=memories

# Option B — Qdrant Cloud — overrides Option A
# QDRANT_URL=https://xyz.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ── Redis ─────────────────────────────────────────────────────────
# Option A — Local Docker (default)
REDIS_HOST=localhost
REDIS_PORT=6379

# Option B — Upstash — overrides Option A
# REDIS_URL=rediss://default:pass@xyz.upstash.io:6379

# ── FalkorDB ──────────────────────────────────────────────────────
# Local Docker only (no free hosted option)
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# ── Embeddings (local, no API cost) ───────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Reranker (local, no API cost) ─────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-base

# ── Memory Tuning ─────────────────────────────────────────────────
DUPLICATE_THRESHOLD=0.80
GRAPH_CONFIDENCE_THRESHOLD=0.85
TOP_K_RETRIEVAL=20
TOP_K_RERANKED=5
MAX_CONTEXT_TOKENS=2000

# ── App ───────────────────────────────────────────────────────────
APP_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────
# URL where the FastAPI backend is running
NEXT_PUBLIC_API_URL=http://localhost:8000
